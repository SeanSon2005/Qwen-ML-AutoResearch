{
  "tools": {
    "approvalMode": "yolo"
  },
  "mcpServers": {
    "train_watchdog": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "train_watchdog_mcp.server"
      ],
      "cwd": "./tools/train-watchdog-mcp",
      "timeout": 86400000,
      "trust": true,
      "includeTools": [
        "train_run"
      ]
    },
    "result_logger": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "result_logger_mcp.server"
      ],
      "cwd": "./tools/result-logger-mcp",
      "timeout": 10000,
      "trust": true,
      "includeTools": [
        "experiment_create",
        "experiment_finish",
        "experiments_list"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$QWEN_PROJECT_DIR/.qwen/hooks/pre_tool_use.py",
            "name": "project-hardlock-policy",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "$version": 3
}
