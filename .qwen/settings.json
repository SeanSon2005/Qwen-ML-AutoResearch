{
  "tools": {
    "approvalMode": "yolo"
  },
  "mcpServers": {
    "train_watchdog": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "train_watchdog_mcp.server"
      ],
      "cwd": "./tools/train-watchdog-mcp",
      "timeout": 86400000,
      "trust": true,
      "includeTools": [
        "train_run"
      ]
    },
    "result_logger": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "result_logger_mcp.server"
      ],
      "cwd": "./tools/result-logger-mcp",
      "timeout": 10000,
      "trust": true,
      "includeTools": [
        "experiment_create",
        "experiment_finish",
        "experiments_list"
      ]
    },
    "paper_search": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "paper_search_mcp.server"
      ],
      "cwd": "./tools/paper-search-mcp-patched",
      "timeout": 30000,
      "trust": true,
      "includeTools": [
        "search_arxiv",
        "search_pubmed",
        "search_biorxiv",
        "search_medrxiv",
        "search_google_scholar",
        "read_arxiv_paper",
        "read_pubmed_paper",
        "read_biorxiv_paper",
        "read_medrxiv_paper"
      ]
    }
  },
  "$version": 3
}
