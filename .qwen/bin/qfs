#!/usr/bin/env python3
"""Controlled filesystem mutator constrained to approved writable roots."""

from __future__ import annotations

import argparse
import shutil
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
if str(SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPT_DIR))

from qpolicy_lib import is_writable_path, print_error_json, resolve_repo_path  # noqa: E402


def validate_target(path_str: str) -> Path | None:
    target = resolve_repo_path(path_str)
    if not is_writable_path(target):
        print_error_json(
            "path_outside_writable_roots",
            code=2,
            extra={"path": str(target), "ok": False},
        )
        return None
    return target


def cmd_touch(path_str: str) -> int:
    target = validate_target(path_str)
    if target is None:
        return 2
    target.parent.mkdir(parents=True, exist_ok=True)
    target.touch(exist_ok=True)
    print(f"{target}")
    return 0


def cmd_mkdir(path_str: str) -> int:
    target = validate_target(path_str)
    if target is None:
        return 2
    target.mkdir(parents=True, exist_ok=True)
    print(f"{target}")
    return 0


def cmd_rm(path_str: str) -> int:
    target = validate_target(path_str)
    if target is None:
        return 2
    if not target.exists():
        return print_error_json("path_not_found", code=3, extra={"path": str(target)})

    if target.is_dir() and not target.is_symlink():
        shutil.rmtree(target)
    else:
        target.unlink()

    print(f"{target}")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(prog="qfs")
    parser.add_argument("operation", choices=["rm", "mkdir", "touch"])
    parser.add_argument("path")
    args = parser.parse_args()

    if args.operation == "touch":
        return cmd_touch(args.path)
    if args.operation == "mkdir":
        return cmd_mkdir(args.path)
    return cmd_rm(args.path)


if __name__ == "__main__":
    raise SystemExit(main())
