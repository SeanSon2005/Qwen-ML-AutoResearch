#!/usr/bin/env python3
"""Async watchdog training runner for Lightning-Hydra workflows."""

from __future__ import annotations

import argparse
import os
import subprocess
import sys
import traceback
from pathlib import Path
from typing import Any

SCRIPT_DIR = Path(__file__).resolve().parent
if str(SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPT_DIR))

from qpolicy_lib import (  # noqa: E402
    ROOT,
    TRAINING_ROOT,
    latest_run_id,
    load_state,
    now_utc_iso,
    pid_alive,
    pretty_json,
    print_error_json,
    read_json,
    run_command_with_timeout,
    run_dir,
    run_id_new,
    save_state,
    traceback_summary,
)


def _parse_run_id(run_id: str | None, use_latest: bool) -> str | None:
    if run_id and use_latest:
        return None
    if run_id:
        return run_id
    if use_latest:
        return latest_run_id()
    return None


def _load_target_state(run_id_value: str | None, use_latest: bool) -> tuple[str | None, dict[str, Any] | None]:
    rid = _parse_run_id(run_id_value, use_latest)
    if not rid:
        return None, None

    state_file = run_dir(rid) / "state.json"
    if not state_file.exists():
        return rid, None

    return rid, read_json(state_file)


def _emit_state_payload(state: dict[str, Any]) -> None:
    payload = {
        "ok": True,
        "run_id": state.get("run_id"),
        "status": state.get("status"),
        "summary": state.get("summary"),
        "created_at": state.get("created_at"),
        "started_at": state.get("started_at"),
        "finished_at": state.get("finished_at"),
        "updated_at": state.get("updated_at"),
        "timeout_sec": state.get("timeout_sec"),
        "require_full": state.get("require_full", False),
        "run_dir": state.get("run_dir"),
        "log_path": state.get("log_path"),
        "worker_log": state.get("worker_log"),
        "train_exit_code": state.get("train_exit_code"),
        "precheck_exit_code": state.get("precheck_exit_code"),
    }
    print(pretty_json(payload))


def _refresh_running_state(state: dict[str, Any]) -> dict[str, Any]:
    status = state.get("status")
    if status not in {"queued", "running"}:
        return state

    pid = state.get("worker_pid")
    if isinstance(pid, int) and pid_alive(pid):
        return state

    state["status"] = "crashed"
    state["finished_at"] = now_utc_iso()
    if not str(state.get("summary", "")).strip():
        state["summary"] = "Watchdog worker is no longer running and did not report completion."
    save_state(str(state["run_id"]), state)
    return state


def cmd_start(args: argparse.Namespace) -> int:
    run_id = run_id_new()
    run_path = run_dir(run_id)
    run_path.mkdir(parents=True, exist_ok=True)

    overrides = list(args.overrides)
    if overrides and overrides[0] == "--":
        overrides = overrides[1:]

    train_log = run_path / "train.log"
    worker_log = run_path / "worker.log"

    state = {
        "run_id": run_id,
        "status": "queued",
        "summary": "Watchdog run queued.",
        "created_at": now_utc_iso(),
        "started_at": None,
        "finished_at": None,
        "updated_at": now_utc_iso(),
        "timeout_sec": args.timeout_sec,
        "require_full": bool(args.require_full),
        "overrides": overrides,
        "run_dir": str(run_path),
        "log_path": str(train_log),
        "worker_log": str(worker_log),
        "worker_pid": None,
        "train_exit_code": None,
        "precheck_exit_code": None,
    }
    save_state(run_id, state)

    worker_cmd = [
        sys.executable,
        str(Path(__file__).resolve()),
        "_worker",
        "--run-id",
        run_id,
        "--timeout-sec",
        str(args.timeout_sec),
    ]
    if args.require_full:
        worker_cmd.append("--require-full")
    if overrides:
        worker_cmd.append("--")
        worker_cmd.extend(overrides)

    with worker_log.open("a", encoding="utf-8") as wf:
        wf.write(f"[qtrain] spawning worker: {' '.join(worker_cmd)}\n")
        wf.flush()
        proc = subprocess.Popen(
            worker_cmd,
            cwd=str(ROOT),
            stdout=wf,
            stderr=wf,
            start_new_session=True,
        )

    state["worker_pid"] = proc.pid
    state["status"] = "running"
    state["summary"] = "Watchdog run started."
    save_state(run_id, state)

    print(
        pretty_json(
            {
                "ok": True,
                "run_id": run_id,
                "status": "running",
                "summary": "Watchdog run started.",
                "run_dir": str(run_path),
                "log_path": str(train_log),
                "worker_log": str(worker_log),
            }
        )
    )
    return 0


def cmd_status(args: argparse.Namespace) -> int:
    rid, state = _load_target_state(args.run_id, args.latest)
    if not rid:
        return print_error_json("no_runs_found", code=2)
    if state is None:
        return print_error_json("run_id_not_found", code=2, extra={"run_id": rid})

    state = _refresh_running_state(state)
    _emit_state_payload(state)
    return 0


def cmd_result(args: argparse.Namespace) -> int:
    rid, state = _load_target_state(args.run_id, args.latest)
    if not rid:
        return print_error_json("no_runs_found", code=2)
    if state is None:
        return print_error_json("run_id_not_found", code=2, extra={"run_id": rid})

    state = _refresh_running_state(state)
    summary = str(state.get("summary", "")).strip()
    if not summary:
        state["summary"] = "No summary recorded; watchdog ended unexpectedly."
        save_state(rid, state)

    _emit_state_payload(state)
    return 0


def cmd_logs(args: argparse.Namespace) -> int:
    rid, state = _load_target_state(args.run_id, args.latest)
    if not rid:
        return print_error_json("no_runs_found", code=2)
    if state is None:
        return print_error_json("run_id_not_found", code=2, extra={"run_id": rid})

    log_path = Path(str(state.get("log_path", "")))
    if not log_path.exists():
        worker_log = Path(str(state.get("worker_log", "")))
        if worker_log.exists():
            log_path = worker_log
        else:
            print(f"[qtrain] no log output is available yet for run_id={rid}")
            return 0

    lines = log_path.read_text(encoding="utf-8", errors="replace").splitlines()
    if args.tail is not None:
        lines = lines[-args.tail :]
    if lines:
        print("\n".join(lines))
    else:
        print(f"[qtrain] log file is empty: {log_path}")
    return 0


def cmd_worker(args: argparse.Namespace) -> int:
    run_id = args.run_id
    overrides = list(args.overrides)
    if overrides and overrides[0] == "--":
        overrides = overrides[1:]

    train_log_path = run_dir(run_id) / "train.log"
    train_log_path.parent.mkdir(parents=True, exist_ok=True)

    try:
        state = load_state(run_id)
    except Exception:
        return 2

    state["status"] = "running"
    state["started_at"] = now_utc_iso()
    state["summary"] = "Watchdog worker running."
    state["worker_pid"] = os.getpid()
    save_state(run_id, state)

    def append_log(text: str) -> None:
        with train_log_path.open("a", encoding="utf-8") as f:
            f.write(text)
            if not text.endswith("\n"):
                f.write("\n")

    try:
        append_log(f"[qtrain] run_id={run_id}")
        append_log(f"[qtrain] require_full={args.require_full}")
        append_log(f"[qtrain] timeout_sec={args.timeout_sec}")
        append_log(f"[qtrain] overrides={overrides}")

        if args.require_full:
            pre_cmd = [str(ROOT / ".qwen" / "bin" / "qtest"), "full"]
            append_log(f"[qtrain] running precheck: {' '.join(pre_cmd)}")
            pre_result = run_command_with_timeout(pre_cmd, cwd=ROOT, timeout_sec=None)
            append_log(pre_result.output)
            state["precheck_exit_code"] = pre_result.returncode
            if pre_result.returncode != 0:
                state["status"] = "failed"
                state["finished_at"] = now_utc_iso()
                state["summary"] = (
                    f"Pre-training full regression failed with exit code {pre_result.returncode}."
                )
                save_state(run_id, state)
                return 1

        train_cmd = ["uv", "run", "python", "-m", "src.train", *overrides]
        append_log(f"[qtrain] running train command: {' '.join(train_cmd)}")

        train_result = run_command_with_timeout(
            train_cmd,
            cwd=TRAINING_ROOT,
            timeout_sec=args.timeout_sec if args.timeout_sec >= 0 else None,
        )
        append_log(train_result.output)

        if train_result.timed_out:
            state["status"] = "timeout"
            state["finished_at"] = now_utc_iso()
            state["summary"] = (
                "Training timed out under watchdog supervision. "
                f"Configured timeout_sec={args.timeout_sec}."
            )
            state["train_exit_code"] = None
            save_state(run_id, state)
            return 124

        state["train_exit_code"] = train_result.returncode
        state["finished_at"] = now_utc_iso()
        if train_result.returncode == 0:
            state["status"] = "success"
            state["summary"] = "Training completed successfully under watchdog supervision."
            save_state(run_id, state)
            return 0

        state["status"] = "failed"
        state["summary"] = f"Training failed with exit code {train_result.returncode}."
        save_state(run_id, state)
        return int(train_result.returncode or 1)

    except Exception:
        state["status"] = "crashed"
        state["finished_at"] = now_utc_iso()
        state["summary"] = traceback_summary("Watchdog worker crashed")
        save_state(run_id, state)
        append_log(state["summary"])
        return 2


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="qtrain")
    sub = parser.add_subparsers(dest="command", required=True)

    start = sub.add_parser("start", help="Start an asynchronous training watchdog run")
    start.add_argument("--timeout-sec", type=int, default=3600)
    start.add_argument("--require-full", action="store_true")
    start.add_argument("overrides", nargs=argparse.REMAINDER)

    status = sub.add_parser("status", help="Show run status")
    status_group = status.add_mutually_exclusive_group(required=False)
    status_group.add_argument("--run-id", type=str)
    status_group.add_argument("--latest", action="store_true")

    logs = sub.add_parser("logs", help="Show run logs")
    logs_group = logs.add_mutually_exclusive_group(required=False)
    logs_group.add_argument("--run-id", type=str)
    logs_group.add_argument("--latest", action="store_true")
    logs.add_argument("--tail", type=int, default=None)

    result = sub.add_parser("result", help="Show run result payload")
    result_group = result.add_mutually_exclusive_group(required=False)
    result_group.add_argument("--run-id", type=str)
    result_group.add_argument("--latest", action="store_true")

    worker = sub.add_parser("_worker", help=argparse.SUPPRESS)
    worker.add_argument("--run-id", required=True)
    worker.add_argument("--timeout-sec", type=int, required=True)
    worker.add_argument("--require-full", action="store_true")
    worker.add_argument("overrides", nargs=argparse.REMAINDER)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    if args.command == "start":
        return cmd_start(args)
    if args.command == "status":
        return cmd_status(args)
    if args.command == "logs":
        return cmd_logs(args)
    if args.command == "result":
        return cmd_result(args)
    if args.command == "_worker":
        return cmd_worker(args)

    return print_error_json("unknown_command", code=2)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        raise SystemExit(130)
    except Exception:
        err = {
            "ok": False,
            "error": "qtrain_unhandled_exception",
            "traceback": traceback.format_exc(),
        }
        print(pretty_json(err))
        raise SystemExit(2)
