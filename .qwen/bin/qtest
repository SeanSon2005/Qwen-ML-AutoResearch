#!/usr/bin/env python3
"""Tiered test runner for unattended Qwen workflows."""

from __future__ import annotations

import argparse
import os
import subprocess
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
if str(SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPT_DIR))

from qpolicy_lib import ROOT  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(prog="qtest")
    parser.add_argument("mode", choices=["fast", "full"], help="Regression tier to run")
    args = parser.parse_args()

    env = os.environ.copy()
    env["PYTEST_DISABLE_PLUGIN_AUTOLOAD"] = "1"

    cmd = ["uv", "run", "pytest", "-q", "training-lightning-hydra/tests"]
    if args.mode == "fast":
        cmd.extend(["-k", "not slow"])

    print(f"[qtest] running: {' '.join(cmd)}")
    result = subprocess.run(cmd, cwd=str(ROOT), env=env)
    return result.returncode


if __name__ == "__main__":
    raise SystemExit(main())
